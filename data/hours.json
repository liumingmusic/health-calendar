  { "name":"申时","range":"15:00–17:00","meridian":"膀胱经当令","organ":"膀胱","color":"#3a6ea5","advice":"宜饮水排毒、适度运动，记忆学习亦佳","avoid":"憋尿、久坐、过劳" },
  { "name":"酉时","range":"17:00–19:00","meridian":"肾经当令","organ":"肾","color":"#2f4858","advice":"宜补肾固本、晚餐宜少、静养收摄","avoid":"过劳耗精、大汗、过咸" },
