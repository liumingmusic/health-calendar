  { "name":"寅时","range":"03:00–05:00","meridian":"肺经当令","organ":"肺","color":"#9fb3c8","advice":"宜安眠将醒，肺朝百脉、输布气血；可晨起深呼吸","avoid":"扰动、受寒、剧烈活动" },
  { "name":"卯时","range":"05:00–07:00","meridian":"大肠经当令","organ":"大肠","color":"#d9c27a","advice":"宜起床排便、饮温水、叩齿吞津、舒缓舒展","avoid":"赖床壅滞" },
