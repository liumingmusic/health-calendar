/* 签运页专属 */
.sign-intro { font-size: 23rpx; color: var(--ink-soft); line-height: 1.6; background: #f6f0e4; border-radius: 12rpx; padding: 16rpx; margin-bottom: 18rpx; }
.sign-stage { display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; }
.qian-tong {
  width: 150rpx; height: 220rpx;
  background: linear-gradient(180deg, #7a4a2b, #5a3420);
  border-radius: 20rpx 20rpx 12rpx 12rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(90,52,32,0.4);
  border-top: 16rpx solid #caa56b;
}
.qt-text { color: #f3e3c8; font-size: 60rpx; font-weight: 700; }
.qian-tong.shaking { animation: shake 0.5s ease-in-out infinite; }
@keyframes shake {
  0%,100% { transform: rotate(-8deg) translateY(0); }
  50% { transform: rotate(8deg) translateY(-10rpx); }
}
.shaking-tip { margin-top: 16rpx; color: var(--seal); font-weight: 600; }

.sign-prompt { text-align: center; }
.prompt-text { font-size: 25rpx; color: var(--ink-soft); line-height: 1.6; margin-bottom: 14rpx; }
.daily-hint { font-size: 23rpx; color: var(--ink-soft); margin-bottom: 18rpx; }

.big-btn {
  background: var(--seal); color: #fff; font-size: 30rpx; font-weight: 600;
  border-radius: 40rpx; padding: 18rpx 0; margin-top: 10rpx;
}
.big-btn.ghost { background: #fff; color: var(--seal); border: 2rpx solid var(--seal); margin-top: 24rpx; }

.sign-result { margin-top: 10rpx; }
.sr-head { text-align: center; font-size: 34rpx; font-weight: 700; color: var(--seal); margin-bottom: 14rpx; }
.sr-poem { display: flex; flex-direction: column; align-items: center; gap: 6rpx; margin-bottom: 16rpx; }
.sr-line { font-size: 30rpx; letter-spacing: 4rpx; color: var(--ink); }
.sr-jie { font-size: 25rpx; line-height: 1.7; background: #f6f0e4; border-radius: 12rpx; padding: 14rpx 18rpx; margin-bottom: 14rpx; }
.sr-jie-h { color: var(--seal); font-weight: 600; margin-right: 10rpx; }
.sr-explain { display: flex; flex-direction: column; gap: 12rpx; }
.sr-para { font-size: 25rpx; line-height: 1.7; color: var(--ink-soft); }

.zodiac-grid { display: flex; flex-wrap: wrap; justify-content: space-between; margin-top: 14rpx; }
.zodiac {
  width: 31%; border-top: 6rpx solid #ccc; background: #f6f0e4; border-radius: 12rpx; padding: 14rpx 10rpx; margin-bottom: 12rpx;
  display: flex; flex-direction: column; align-items: center;
}
.zx-name { font-size: 30rpx; font-weight: 700; }
.zx-zhi { font-size: 22rpx; color: var(--ink-soft); }
.zx-badge { color: #fff; font-size: 20rpx; padding: 2rpx 14rpx; border-radius: 20rpx; margin: 6rpx 0; }
.zx-comment { font-size: 20rpx; color: var(--ink-soft); line-height: 1.4; text-align: center; }
.fortune-lead { font-size: 25rpx; color: var(--ink); margin-bottom: 8rpx; }
.fortune-zong { margin-top: 16rpx; background: #f6f0e4; border-radius: 12rpx; padding: 16rpx; font-size: 24rpx; color: var(--ink-soft); line-height: 1.7; }
.dz-h { color: var(--seal); font-weight: 600; margin-right: 8rpx; }

.my-sign-row { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1rpx dashed var(--line); font-size: 24rpx; }
.my-sign-row:last-child { border-bottom: none; }
.ms-date { width: 200rpx; color: var(--ink-soft); flex-shrink: 0; }
.ms-no { width: 130rpx; color: var(--seal); font-weight: 600; flex-shrink: 0; }
.ms-title { flex: 1; }

.pro-hint { margin-top: 22rpx; font-size: 24rpx; color: var(--ink-soft); text-align: center; background: #f6f0e4; border-radius: 12rpx; padding: 18rpx; }
