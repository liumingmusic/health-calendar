/* 黄历页专属 */
.pillars { display: flex; gap: 12rpx; }
.pillar {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  background: #f6f0e4; border-radius: 14rpx; padding: 16rpx 8rpx;
}
.pillar.rz { background: #f3eef8; border: 1rpx solid #e0d2ee; }
.p-label { font-size: 22rpx; color: var(--ink-soft); }
.p-gz { font-size: 38rpx; font-weight: 700; color: var(--seal); }
.p-wx { font-size: 22rpx; color: var(--ink-soft); }
.p-nayin { font-size: 20rpx; color: #9a8f7a; }

.wx-bars { margin-top: 22rpx; }
.wx-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.wx-name { width: 44rpx; font-size: 24rpx; font-weight: 600; }
.wx-track { flex: 1; height: 18rpx; background: #ece2cf; border-radius: 10rpx; margin: 0 16rpx; overflow: hidden; }
.wx-fill { height: 100%; border-radius: 10rpx; }
.wx-val { width: 40rpx; text-align: right; font-size: 24rpx; color: var(--ink-soft); }

.wx-mu { color: #5f8a3a; } .wx-huo { color: #c4452f; } .wx-tu { color: #cf9a1c; } .wx-jin { color: #b8862f; } .wx-shui { color: #3a6a8a; }
.wx-mu.wx-fill, .wx-fill.wx-mu { background: #5f8a3a; }
.wx-huo.wx-fill, .wx-fill.wx-huo { background: #c4452f; }
.wx-tu.wx-fill, .wx-fill.wx-tu { background: #cf9a1c; }
.wx-jin.wx-fill, .wx-fill.wx-jin { background: #b8862f; }
.wx-shui.wx-fill, .wx-fill.wx-shui { background: #3a6a8a; }
.wx-dot { display: inline-block; width: 20rpx; height: 20rpx; border-radius: 50%; margin-right: 10rpx; }
.wx-dot.wx-mu { background: #5f8a3a; } .wx-dot.wx-huo { background: #c4452f; }
.wx-dot.wx-tu { background: #cf9a1c; } .wx-dot.wx-jin { background: #b8862f; } .wx-dot.wx-shui { background: #3a6a8a; }

.profile-box { margin-top: 24rpx; background: #f3eef8; border: 1rpx solid #e0d2ee; border-radius: 14rpx; padding: 20rpx; }
.profile-empty { margin-top: 24rpx; }
.pz-rel { color: var(--seal); font-weight: 600; margin-bottom: 14rpx; }
.pv-advice { margin-top: 14rpx; }
.pv-head { font-weight: 600; display: flex; align-items: center; margin-bottom: 6rpx; }
.pv-li { font-size: 24rpx; color: var(--ink-soft); }

.alm-row { display: flex; align-items: baseline; padding: 8rpx 0; font-size: 26rpx; }
.alm-k { width: 110rpx; color: var(--seal); font-weight: 600; flex-shrink: 0; }
.alm-row .small { font-size: 22rpx; color: var(--ink-soft); }
.alm-yi, .alm-ji { font-size: 25rpx; padding: 6rpx 0; }
.alm-yi { color: var(--green); }
.alm-ji { color: var(--red); }
.huang { color: var(--green); font-weight: 600; }
.hei { color: var(--red); font-weight: 600; }
.alm-grid { display: flex; flex-wrap: wrap; margin-top: 8rpx; }
.alm-grid .alm-row { width: 50%; }
.alm-mer { margin-top: 16rpx; border-top: 1rpx dashed var(--line); padding-top: 16rpx; }

/* 奇门九宫 */
.qm-cap { font-size: 24rpx; color: var(--seal); margin-bottom: 14rpx; text-align: center; }
.qm-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.qm-cell {
  position: relative; width: 32%; min-height: 130rpx; margin-bottom: 8rpx;
  background: #f6f0e4; border-radius: 10rpx; padding: 10rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  font-size: 20rpx;
}
.qm-cell.center { background: #efe6d6; }
.qm-cell.zhifu { box-shadow: inset 0 0 0 3rpx var(--seal); }
.qm-cell.zhishi { box-shadow: inset 0 0 0 3rpx var(--acu); }
.qm-luoshu { position: absolute; top: 6rpx; left: 8rpx; font-size: 18rpx; color: #9a8f7a; }
.qm-gua { position: absolute; top: 6rpx; right: 8rpx; font-size: 18rpx; color: #9a8f7a; }
.qm-dir { position: absolute; bottom: 4rpx; right: 8rpx; font-size: 18rpx; color: #9a8f7a; }
.qm-shen { color: var(--seal); font-weight: 700; font-size: 22rpx; }
.qm-star { color: #5a4a32; font-weight: 600; }
.qm-men { color: var(--acu); font-weight: 600; }
.qm-yi { color: #3a6a8a; }
.qm-note { font-size: 22rpx; color: var(--ink-soft); margin-top: 12rpx; text-align: center; }

/* 六十甲子 */
.gz-section { margin-top: 16rpx; }
.gz-h { font-size: 24rpx; color: var(--seal); font-weight: 600; margin-bottom: 10rpx; }
.gz-table { display: flex; flex-wrap: wrap; gap: 8rpx; }
.gz-tr { display: flex; background: #f6f0e4; border-radius: 8rpx; overflow: hidden; }
.gz-tr.gz-now { background: #f3eef8; box-shadow: inset 0 0 0 2rpx var(--seal); }
.gz-c { padding: 8rpx 12rpx; font-size: 22rpx; border-right: 1rpx solid #ece2cf; }
.gz-c:last-child { border-right: none; }
.gz-jiazi { display: flex; flex-wrap: wrap; gap: 8rpx; }
.gz-jz { padding: 8rpx 12rpx; background: #f6f0e4; border-radius: 8rpx; font-size: 22rpx; }
.gz-jz.now { background: #f3eef8; color: var(--seal); font-weight: 700; box-shadow: inset 0 0 0 2rpx var(--seal); }

.pro-hint { margin-top: 22rpx; font-size: 24rpx; color: var(--ink-soft); text-align: center; background: #f6f0e4; border-radius: 12rpx; padding: 18rpx; }
