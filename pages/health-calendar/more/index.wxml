<view class="disclaimer-bar">{{disclaimerText}}</view>
<view class="page more">

  <!-- 全年总览：节气 + 时辰 + 七十二候 -->
  <view class="card">
    <view class="card-head"><text class="ch-title">全年总览</text><text class="ch-sub">节气 · 时辰 · 七十二候</text></view>
    <view class="card-body">
      <view class="block-title"><text class="dot"></text>二十四节气</view>
      <view class="season-tabs">
        <view wx:for="{{seasonTabs}}" wx:key="key" class="season-tab {{activeSeason === item.key ? 'active' : ''}}"
              data-key="{{item.key}}" bindtap="setSeason">{{item.label}}</view>
      </view>
      <view class="term-grid">
        <view wx:for="{{terms}}" wx:key="term"
              wx:if="{{activeSeason === 'all' || item.season === activeSeason}}"
              class="term-cell {{item.isCur ? 'current' : ''}}"
              style="border-color:{{item.color}}">
          <text class="t-name">{{item.term}}</text>
          <text class="t-solar">{{item.mmdd}}</text>
        </view>
      </view>

      <view class="block-title"><text class="dot"></text>十二时辰 · 子午流注</view>
      <view class="hour-bar">
        <view wx:for="{{hourSegs}}" wx:key="i" class="hour-seg {{item.current ? 'current' : ''}} {{selHour === item.i ? 'sel' : ''}}"
              style="background:{{item.color}}" data-i="{{item.i}}" bindtap="tapHour">
          <text class="hs-name">{{item.name}}</text>
          <text class="hs-range">{{item.range}}</text>
        </view>
      </view>
      <view class="hour-detail">
        <view class="hd-head"><text class="hd-title">{{hourDetail.name}}时</text><text class="hd-meridian">{{hourDetail.meridian}} · {{hourDetail.range}}</text></view>
        <view class="hd-advice">宜：{{hourDetail.advice}}</view>
        <view class="hd-avoid">忌：{{hourDetail.avoid}}</view>
      </view>

      <view class="block-title"><text class="dot"></text>七十二候 · 全年候历</view>
      <view class="hou-year">
        <view wx:for="{{houGroups}}" wx:key="term" class="hou-year-group">
          <view class="hy-term">{{item.term}}</view>
          <view wx:for="{{item.rows}}" wx:for-item="h" wx:key="name" class="hy-row">
            <text class="hy-name">{{h.label}} · {{h.name}}</text>
            <text class="hy-phenom">{{h.phenom}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="card">
    <view class="card-head plain"><text class="ch-title">使用说明 · 怎么看这款小应用</text></view>
    <view class="card-body">
      <view class="help-today">
        <view class="ht-row"><text class="ht-k">今日节气</text><text class="ht-v">{{helpToday.term}}</text></view>
        <view class="ht-row"><text class="ht-k">当前时辰</text><text class="ht-v">{{helpToday.hour}}</text></view>
        <view class="ht-row"><text class="ht-k">今日日干支</text><text class="ht-v">{{helpToday.ganzhi}}</text></view>
        <view class="ht-row"><text class="ht-k">农历标注</text><text class="ht-v">{{helpToday.lunar}}</text></view>
      </view>
      <view wx:for="{{help}}" wx:key="title" class="help-item" data-i="{{index}}" bindtap="toggleHelp">
        <view class="hi-summary">
          <text class="hi-caret {{item.open ? 'open' : ''}}">▸</text>
          <text class="hi-title">{{item.title}}</text>
        </view>
        <view wx:if="{{item.open}}" class="hi-body">
          <view wx:for="{{item.items}}" wx:for-item="it" wx:key="*this" class="hi-li">{{it}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="card-head plain"><text class="ch-title">设置</text></view>
    <view class="card-body">
      <view class="set-row">
        <text class="set-k">显示模式</text>
        <view class="mode-switch">
          <view class="mode-btn {{mode === 'novice' ? 'active' : ''}}" data-mode="novice" bindtap="setMode">简明</view>
          <view class="mode-btn {{mode === 'pro' ? 'active' : ''}}" data-mode="pro" bindtap="setMode">进阶</view>
        </view>
      </view>
      <view class="set-tip">简明：仅养生与八字摘要；进阶：额外显示奇门遁甲、六十甲子、生肖运程。</view>
      <view class="set-row" bindtap="goProfile">
        <text class="set-k">生辰录入</text>
        <text class="set-v {{hasProfile ? 'on' : ''}}">{{hasProfile ? '已录入 · 点击修改' : '未录入 · 点击录入'}} ›</text>
      </view>
    </view>
  </view>

  <!-- 免责声明 -->
  <view class="card">
    <view class="card-head plain"><text class="ch-title">免责声明</text></view>
    <view class="card-body">
      <view class="disclaimer-full">{{disclaimerText}}</view>
      <view class="disclaimer-full">八字、签运、生肖运程等内容均为中国传统民俗文化，仅供修身自省与文化交流，不构成医疗诊断、治疗建议或吉凶占断。如有健康问题，请及时就医并遵医嘱。</view>
    </view>
  </view>

  <view class="footer-note">养生日历 · 小程序版 · 纯本地数据，离线可用</view>
</view>
