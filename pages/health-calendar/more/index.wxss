/* 更多页专属 */
.card-head { color: var(--ink); display: flex; justify-content: space-between; align-items: baseline; padding: 20rpx 26rpx; border-bottom: 1rpx solid var(--line); }
.ch-title { font-size: 30rpx; font-weight: 700; color: var(--seal); }
.ch-sub { font-size: 21rpx; color: var(--ink-soft); }

.block-title { font-size: 28rpx; font-weight: 600; color: var(--seal); margin: 24rpx 0 14rpx; display: flex; align-items: center; }
.block-title:first-child { margin-top: 0; }
.dot { display: inline-block; width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--seal); margin-right: 12rpx; }

.set-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx dashed var(--line); }
.set-row:last-child { border-bottom: none; }
.set-k { font-weight: 600; color: var(--seal); }
.set-v { color: var(--ink-soft); font-size: 25rpx; }
.set-v.on { color: var(--green); }
.set-tip { font-size: 22rpx; color: var(--ink-soft); margin-top: 12rpx; line-height: 1.6; }

.mode-switch { display: flex; background: #ece2cf; border-radius: 30rpx; padding: 4rpx; }
.mode-btn { padding: 10rpx 28rpx; border-radius: 26rpx; font-size: 26rpx; color: var(--ink-soft); }
.mode-btn.active { background: var(--seal); color: #fff; font-weight: 600; }

.season-tabs { display: flex; gap: 10rpx; margin-bottom: 18rpx; flex-wrap: wrap; }
.season-tab { padding: 8rpx 24rpx; background: #ece2cf; border-radius: 26rpx; font-size: 24rpx; color: var(--ink-soft); }
.season-tab.active { background: var(--seal); color: #fff; }

.term-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.term-cell {
  width: 23%; border: 2rpx solid #ccc; border-radius: 12rpx; padding: 14rpx 6rpx; margin-bottom: 12rpx;
  display: flex; flex-direction: column; align-items: center;
}
.term-cell.current { background: #f3eef8; box-shadow: inset 0 0 0 3rpx var(--seal); }
.t-name { font-size: 26rpx; font-weight: 600; }
.t-solar { font-size: 20rpx; color: var(--ink-soft); margin-top: 4rpx; }

/* 十二时辰 */
.hour-bar { display: flex; flex-wrap: wrap; gap: 8rpx; }
.hour-seg {
  width: 23%; border-radius: 10rpx; padding: 12rpx 4rpx; margin-bottom: 8rpx;
  display: flex; flex-direction: column; align-items: center; color: #fff; opacity: 0.78;
}
.hour-seg.current { opacity: 1; box-shadow: inset 0 0 0 3rpx #fff; }
.hour-seg.sel { box-shadow: 0 0 0 3rpx var(--seal); opacity: 1; }
.hs-name { font-size: 24rpx; font-weight: 600; }
.hs-range { font-size: 18rpx; opacity: 0.92; }
.hour-detail { margin-top: 14rpx; background: #f6f0e4; border-radius: 12rpx; padding: 16rpx; }
.hd-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 8rpx; }
.hd-title { font-size: 28rpx; font-weight: 700; color: var(--seal); }
.hd-meridian { font-size: 22rpx; color: var(--ink-soft); }
.hd-advice { font-size: 24rpx; color: var(--green); line-height: 1.6; }
.hd-avoid { font-size: 24rpx; color: var(--red); line-height: 1.6; }

/* 七十二候 */
.hou-year { display: flex; flex-direction: column; gap: 10rpx; }
.hou-year-group { background: #f6f0e4; border-radius: 12rpx; padding: 14rpx 16rpx; }
.hy-term { font-size: 26rpx; font-weight: 700; color: var(--seal); margin-bottom: 8rpx; }
.hy-row { display: flex; align-items: baseline; padding: 5rpx 0; }
.hy-name { width: 240rpx; font-size: 24rpx; font-weight: 600; flex-shrink: 0; }
.hy-phenom { flex: 1; font-size: 22rpx; color: var(--ink-soft); line-height: 1.5; }

/* 使用说明 */
.help-today { background: #f3eef8; border: 1rpx solid #e0d2ee; border-radius: 12rpx; padding: 14rpx 16rpx; margin-bottom: 16rpx; }
.ht-row { display: flex; align-items: baseline; padding: 6rpx 0; }
.ht-k { width: 150rpx; color: var(--seal); font-weight: 600; font-size: 23rpx; flex-shrink: 0; }
.ht-v { flex: 1; font-size: 24rpx; color: var(--ink); }
.help-item { border-bottom: 1rpx dashed var(--line); padding: 14rpx 0; }
.help-item:last-child { border-bottom: none; }
.hi-summary { display: flex; align-items: center; }
.hi-caret { color: var(--seal); margin-right: 12rpx; transition: transform 0.2s; }
.hi-caret.open { transform: rotate(90deg); }
.hi-title { font-size: 26rpx; font-weight: 600; color: var(--ink); }
.hi-body { margin-top: 10rpx; padding-left: 36rpx; }
.hi-li { font-size: 23rpx; color: var(--ink-soft); line-height: 1.7; margin-bottom: 8rpx; }
.hi-li:last-child { margin-bottom: 0; }

.disclaimer-full { font-size: 23rpx; color: var(--ink-soft); line-height: 1.7; margin-bottom: 14rpx; }
.disclaimer-full:last-child { margin-bottom: 0; }
